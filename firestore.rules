rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['username', 'xp', 'level', 'streak', 'lastActiveDate', 'totalAnswered', 'totalCorrect', 'totalWrong', 'survivalHighScore']) 
             && data.keys().size() == 9
             && data.username is string && data.username.size() >= 3 && data.username.size() <= 32
             && data.xp is int && data.xp >= 0
             && data.level is int && data.level >= 1
             && data.streak is int && data.streak >= 0
             && data.lastActiveDate is string && data.lastActiveDate.size() == 10
             && data.totalAnswered is int && data.totalAnswered >= 0
             && data.totalCorrect is int && data.totalCorrect >= 0
             && data.totalWrong is int && data.totalWrong >= 0
             && data.survivalHighScore is int && data.survivalHighScore >= 0;
    }

    // Match rules for the users collection
    match /users/{userId} {
      allow get: if isValidId(userId);
      allow list: if true; // Public access for classmates leaderboard
      
      allow create: if isValidId(userId)
                    && isValidUserProfile(request.resource.data);
                    
      allow update: if isValidId(userId)
                    && isValidUserProfile(request.resource.data);
                    
      allow delete: if false; // Profiles cannot be deleted from the client
    }
  }
}
